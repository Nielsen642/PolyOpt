# =============================================================================
# POLYOPT – Environment template
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
SESSION_SECRET=your-secret-at-least-32-chars-long

# Set DEMO_MODE=true to seed demo portfolios/positions on register. When unset or false,
# Polymarket is the source of truth: connect a wallet and use "Sync wallet to account" on Integrations.
# DEMO_MODE=true

# Optimizer (optional). Default: uv run python server/optimize.py (requires uv and pyproject deps).
# If you use plain Python instead, set e.g. OPTIMIZER_CMD=python and install numpy, cvxpy (see pyproject.toml).
# OPTIMIZER_CMD=
# OPTIMIZER_ARGS=server/optimize.py

# -----------------------------------------------------------------------------
# Polymarket – data address (optional; used for position/market API data only)
# Set to your Polymarket proxy wallet or EOA. When set, all position/dashboard data
# is fetched for this address. Signing and order submission use the app-connected wallet.
# -----------------------------------------------------------------------------
POLYMARKET_WALLET_ADDRESS=

# -----------------------------------------------------------------------------
# Pro / production tier (optional)
# -----------------------------------------------------------------------------
# Enables: API rate limits, security headers, trust proxy, PostgreSQL-backed alert sync,
# enriched market feed metadata, institutional risk report API, server-side CLOB header merge.
# APP_TIER=pro
# Alternative: PRO_MODE=1
#
# Warn when the browser has not successfully refreshed markets for this long (ms). Default 120000.
# FEED_STALE_WARNING_MS=120000
#
# API rate limits (per client IP) when Pro is on. Defaults shown.
# API_RATE_LIMIT_WINDOW_MS=60000
# API_RATE_LIMIT_MAX=300
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=40
#
# Server-side Polymarket CLOB L2 headers (never expose in the UI). Used when APP_TIER=pro if the
# browser does not send POLY_* headers. Populate from your Polymarket builder credentials.
# POLY_API_KEY=
# POLY_ADDRESS=
# POLY_PASSPHRASE=
# Optional: builder secret (base64). If set, the server auto-generates POLY_SIGNATURE and
# POLY_TIMESTAMP for /order relay requests.
# POLY_SECRET=
# Optional static overrides; usually leave unset when POLY_SECRET is configured.
# POLY_SIGNATURE=
# POLY_TIMESTAMP=

# -----------------------------------------------------------------------------
# Polymarket API resilience (optional; defaults are used if unset)
# -----------------------------------------------------------------------------
# POLYMARKET_RETRY_ATTEMPTS=3
# POLYMARKET_RETRY_BASE_DELAY_MS=500
# POLYMARKET_DATA_TIMEOUT_MS=20000
# POLYMARKET_GAMMA_TIMEOUT_MS=20000
# POLYMARKET_CLOB_TIMEOUT_MS=20000

# -----------------------------------------------------------------------------
# Frontend – WalletConnect (optional; leave empty to hide QR connect)
# -----------------------------------------------------------------------------
VITE_WALLETCONNECT_PROJECT_ID=

# -----------------------------------------------------------------------------
# Frontend – Supabase Realtime (optional; leave empty to use built-in WebSocket)
# Advanced: only configure for multi-instance realtime; desktop users can leave blank.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_MARKETS_CHANNEL=polyopt:markets
VITE_SUPABASE_ALERTS_CHANNEL=polyopt:alerts

# -----------------------------------------------------------------------------
# Frontend – API base URL (optional; defaults to current origin)
# -----------------------------------------------------------------------------
VITE_BACKEND_URL=
